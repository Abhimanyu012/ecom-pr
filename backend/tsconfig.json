{
  "compilerOptions": {
    "target": "ES2022",                /* Latest stable ECMAScript features */
    "module": "NodeNext",              /* Best for modern Node.js ESM projects */
    "moduleResolution": "NodeNext",
    "outDir": "./dist",                /* Where compiled JS goes */
    "rootDir": "./src",                /* Where your TS source code lives */
    "strict": true,                    /* Enable all strict type-checking */
    "esModuleInterop": true,           /* Fixes compatibility with CommonJS modules */
    "skipLibCheck": true,              /* Speeds up build by skipping .d.ts checks */
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
